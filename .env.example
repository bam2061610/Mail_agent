# Copy this file to backend/.env before running.
# Leave DATABASE_URL unset to use the backend/app default absolute path.
APP_NAME=Orhun Mail Agent
APP_ENV=development
DEBUG=true

# DATABASE_URL=sqlite:////absolute/path/to/backend/data/mail_agent.db

IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=

SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=true

OPENAI_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
AI_MAX_RETRIES=3
AI_TIMEOUT_SECONDS=60
REDIS_URL=redis://localhost:6379/0
SCAN_INTERVAL_MINUTES=5
FOLLOWUP_OVERDUE_DAYS=3
