# Copy this file to backend/.env before running.
# Leave DATABASE_URL unset to use the backend/app default absolute path.
APP_NAME=Orhun Mail Agent
APP_ENV=development
DEBUG=true
DEV_AUTH_BYPASS=false
# Optional first-run admin bootstrap for local setup only.
# If BOOTSTRAP_DEFAULT_ADMIN=true and BOOTSTRAP_ADMIN_PASSWORD is blank,
# the app will generate a random password and print it once in backend logs.
BOOTSTRAP_DEFAULT_ADMIN=false
BOOTSTRAP_ADMIN_EMAIL=admin@orhun.local
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_FULL_NAME=Bootstrap Admin

# DATABASE_URL=sqlite:////absolute/path/to/backend/data/mail_agent.db

IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=

SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=true

OPENAI_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
AI_MAX_RETRIES=3
AI_TIMEOUT_SECONDS=60
# Reserved for future queue/cache integrations; unused in current runtime.
REDIS_URL=redis://localhost:6379/0
# Enable automatic spam classification from AI analysis.
AI_AUTO_SPAM_ENABLED=true
SCAN_INTERVAL_MINUTES=5
FOLLOWUP_OVERDUE_DAYS=3
# Keep these true for single-process local runs.
# In Docker/production, disable them on API and enable them on the dedicated worker service.
RUN_BACKGROUND_JOBS=true
RUN_MAIL_WATCHERS=true
